---
const features = [
  {
    icon: "f(x)",
    title: "Pure Functions",
    description:
      "Give it a keystroke and state, get back new state and actions. No side effects, no DOM, no surprises.",
  },
  {
    icon: "∅",
    title: "Zero Dependencies",
    description:
      "Pure TypeScript. No runtime baggage. The core engine is just 2.8kB gzipped.",
  },
  {
    icon: "</>",
    title: "Any Framework",
    description:
      "React, Vue, Svelte, vanilla JS — bindings are thin wrappers over the pure engine.",
  },
];
---

<section
  id="what-is-vimee"
  class="relative py-24 px-6 overflow-hidden opacity-0 translate-y-8"
  data-animate
>
  <div class="max-w-5xl mx-auto text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
      What is vimee?
    </h2>
    <p class="text-lg md:text-xl text-text-primary/60">
      A headless Vim engine that runs anywhere JavaScript does.
    </p>
  </div>

  <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
    {
      features.map((feature) => (
        <div class="bg-surface border border-border-subtle rounded-xl p-6">
          <div class="text-3xl font-mono text-accent-purple mb-4">
            {feature.icon}
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-2">
            {feature.title}
          </h3>
          <p class="text-text-primary/60 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))
    }
  </div>

</section>
