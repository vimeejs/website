---
import GhostCharacter from "./GhostCharacter.astro";
---

<footer class="py-12 px-6 border-t border-border-subtle">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between">
      <nav class="flex gap-6">
        <a
          href="https://github.com/vimeejs/vimee"
          target="_blank"
          rel="noopener"
          class="text-sm text-text-primary/40 hover:text-text-primary/60 transition-colors duration-200"
        >
          GitHub
        </a>
        <a
          href="https://www.npmjs.com/package/@vimee/core"
          target="_blank"
          rel="noopener"
          class="text-sm text-text-primary/40 hover:text-text-primary/60 transition-colors duration-200"
        >
          npm
        </a>
        <a
          href="https://playground.vimee.dev"
          target="_blank"
          rel="noopener"
          class="text-sm text-text-primary/40 hover:text-text-primary/60 transition-colors duration-200"
        >
          Playground
        </a>
      </nav>

      <GhostCharacter variant="wave" />
    </div>

    <p class="text-xs text-text-primary/20 text-center mt-8">
      Built with love and pure functions
    </p>
  </div>
</footer>
