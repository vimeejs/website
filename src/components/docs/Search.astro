<div id="search-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 bg-black/60" id="search-backdrop"></div>
  <div class="relative mx-auto mt-[15vh] max-w-lg bg-bg-surface border border-border rounded-xl shadow-2xl overflow-hidden">
    <div id="search-container" class="p-4">
      <p class="text-text-dim text-sm text-center py-8">
        Search available after build. Run <code>bun run preview</code> to test.
      </p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("search-modal");
  const backdrop = document.getElementById("search-backdrop");
  const trigger = document.getElementById("search-trigger");
  const container = document.getElementById("search-container");

  function openSearch() {
    modal?.classList.remove("hidden");
    if (container && !container.dataset.loaded) {
      loadPagefind();
      container.dataset.loaded = "true";
    }
  }

  function closeSearch() {
    modal?.classList.add("hidden");
  }

  async function loadPagefind() {
    try {
      // @ts-ignore — Pagefind is loaded from built assets
      const pagefind = await import("/pagefind/pagefind.js");
      await pagefind.init();
      if (!container) return;

      container.replaceChildren();

      const input = document.createElement("input");
      input.id = "search-input";
      input.type = "text";
      input.placeholder = "Search docs...";
      input.className = "w-full bg-transparent border-b border-border px-2 py-3 text-text outline-none";
      input.autofocus = true;
      container.appendChild(input);

      const resultsDiv = document.createElement("div");
      resultsDiv.id = "search-results";
      resultsDiv.className = "max-h-[50vh] overflow-y-auto";
      container.appendChild(resultsDiv);

      input.addEventListener("input", async () => {
        const query = input.value;
        if (!query) {
          resultsDiv.replaceChildren();
          return;
        }
        const search = await pagefind.search(query);
        const items = await Promise.all(
          search.results.slice(0, 8).map((r: any) => r.data()),
        );

        resultsDiv.replaceChildren();
        for (const item of items) {
          const link = document.createElement("a");
          link.href = item.url;
          link.className = "block px-2 py-3 hover:bg-bg-surface-hover transition-colors border-b border-border last:border-0";

          const titleEl = document.createElement("div");
          titleEl.className = "text-sm font-medium text-text";
          titleEl.textContent = item.meta?.title || item.url;
          link.appendChild(titleEl);

          const excerptEl = document.createElement("div");
          excerptEl.className = "text-xs text-text-dim mt-1 line-clamp-2";
          excerptEl.textContent = item.excerpt?.replace(/<[^>]*>/g, "") || "";
          link.appendChild(excerptEl);

          resultsDiv.appendChild(link);
        }
      });

      input.focus();
    } catch {
      if (container) {
        container.replaceChildren();
        const msg = document.createElement("p");
        msg.className = "text-text-dim text-sm text-center py-8";
        msg.textContent = "Search index not found. Run bun run build first.";
        container.appendChild(msg);
      }
    }
  }

  trigger?.addEventListener("click", openSearch);
  backdrop?.addEventListener("click", closeSearch);
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
    }
    if (e.key === "Escape") closeSearch();
  });
</script>
