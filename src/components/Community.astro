---
---

<section id="community" class="py-24 md:py-32 px-6" data-animate>
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-4">Community</h2>
    <p class="text-lg text-text-primary/60 mb-12">
      vimee is open source. Join us.
    </p>

    <div class="flex flex-col items-center gap-6">
      <a
        href="https://github.com/vimeejs/vimee"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center border border-white/20 hover:border-white/40 hover:bg-white/5 transition-all duration-200 text-text-primary font-semibold rounded-lg px-8 py-3"
      >
        Contribute on GitHub
      </a>

      <a
        href="https://playground.vimee.dev"
        target="_blank"
        rel="noopener"
        class="text-sm text-text-primary/60 hover:text-text-primary/80 transition-colors duration-200 underline underline-offset-4"
      >
        Try the Playground
      </a>

      <span class="bg-accent-purple/10 text-accent-purple text-xs font-mono px-3 py-1 rounded-full">
        MIT License
      </span>
    </div>
  </div>
</section>
