---
const features = [
  {
    glyph: "N I V",
    title: "Six Editing Modes",
    description:
      "Normal, Insert, Visual, Visual-Line, Visual-Block, and Command-Line — all faithfully implemented.",
  },
  {
    glyph: "hjkl",
    title: "Rich Motions",
    description:
      "h j k l w b e 0 $ ^ gg G f F t T — navigate with the full Vim vocabulary.",
  },
  {
    glyph: "3dd",
    title: "Operators & Counts",
    description:
      'd y c > < combined with motions, text objects, and counts. 3dd, 2dw, ci" — it just works.',
  },
  {
    glyph: "iw",
    title: "Text Objects",
    description:
      'iw aw i" a" i( a( i[ a[ i{ a{ — select and operate on semantic chunks of text.',
  },
  {
    glyph: "/",
    title: "Search & Replace",
    description:
      "/pattern n N for searching, :s/old/new/g for replacing. Full regex support.",
  },
  {
    glyph: "q@",
    title: "Macros & Marks",
    description:
      "q{a-z} to record, @{a-z} to play. m{a-z} to mark, '{a-z} to jump. Automate everything.",
  },
];
---

<section id="features" class="py-24 md:py-32 px-6" data-animate>
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-4">Features</h2>
    <p class="text-lg text-text-primary/60 text-center mb-12">
      Everything you expect from Vim, in a pure JavaScript engine.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        features.map((feature) => (
          <div class="bg-surface border border-border-subtle rounded-xl p-6 hover:border-accent-purple/30 hover:bg-surface transition-all duration-300 text-center">
            <div class="w-12 h-12 rounded-lg bg-accent-purple/10 flex items-center justify-center mx-auto">
              <span class="text-accent-purple font-mono text-lg font-bold">
                {feature.glyph}
              </span>
            </div>
            <h3 class="text-lg font-semibold text-text-primary mt-4 mb-2">
              {feature.title}
            </h3>
            <p class="text-sm text-text-primary/60 leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
