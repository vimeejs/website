---
const vimActions = [
  "cursor-move",
  "content-change",
  "mode-change",
  "yank",
  "save",
  "status-message",
  "scroll",
];

const sellingPoints = [
  {
    title: "No DOM Access",
    description: "The engine never touches the DOM.",
  },
  {
    title: "No Side Effects",
    description: "Pure in, pure out. Every time.",
  },
  {
    title: "Fully Testable",
    description: "Unit test every keystroke.",
  },
  {
    title: "Framework Agnostic",
    description: "Works everywhere JS runs.",
  },
];
---

<section id="architecture" class="py-24 md:py-32 px-6" data-animate>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-4">Architecture</h2>
    <p class="text-lg text-text-primary/60 text-center mb-16">
      One pure function. No side effects. No surprises.
    </p>

    <!-- Diagram -->
    <div class="diagram flex flex-col md:flex-row items-center justify-center gap-0 mb-16">
      <!-- Input Box -->
      <div class="bg-surface border border-border-subtle rounded-xl p-6 w-full md:w-auto md:min-w-[200px] text-center">
        <h3 class="text-sm font-semibold text-text-primary/60 uppercase tracking-wider mb-3">Input</h3>
        <div class="flex flex-col gap-2">
          <code class="text-text-code font-mono text-sm bg-accent-purple/5 rounded-md px-3 py-1.5 inline-block">keystroke</code>
          <code class="text-text-code font-mono text-sm bg-accent-purple/5 rounded-md px-3 py-1.5 inline-block">state</code>
        </div>
      </div>

      <!-- Arrow (horizontal on desktop, vertical on mobile) -->
      <div class="arrow-connector flex items-center justify-center shrink-0">
        <!-- Vertical arrow (mobile) -->
        <div class="block md:hidden py-3">
          <svg width="24" height="40" viewBox="0 0 24 40" fill="none" class="text-accent-purple/50">
            <path d="M12 0 L12 32 M6 26 L12 34 L18 26" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <!-- Horizontal arrow (desktop) -->
        <div class="hidden md:block px-3">
          <svg width="48" height="24" viewBox="0 0 48 24" fill="none" class="text-accent-purple/50">
            <path d="M0 12 L40 12 M34 6 L42 12 L34 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      </div>

      <!-- Center Box (processor, highlighted) -->
      <div class="process-box bg-accent-purple/10 border border-accent-purple/30 rounded-xl p-6 w-full md:w-auto md:min-w-[240px] text-center relative">
        <div class="absolute inset-0 rounded-xl bg-accent-purple/5 blur-xl -z-10"></div>
        <h3 class="text-sm font-semibold text-text-primary/60 uppercase tracking-wider mb-3">Processor</h3>
        <code class="text-accent-purple font-mono text-base font-semibold">processKeystroke()</code>
      </div>

      <!-- Arrow (horizontal on desktop, vertical on mobile) -->
      <div class="arrow-connector flex items-center justify-center shrink-0">
        <!-- Vertical arrow (mobile) -->
        <div class="block md:hidden py-3">
          <svg width="24" height="40" viewBox="0 0 24 40" fill="none" class="text-accent-purple/50">
            <path d="M12 0 L12 32 M6 26 L12 34 L18 26" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <!-- Horizontal arrow (desktop) -->
        <div class="hidden md:block px-3">
          <svg width="48" height="24" viewBox="0 0 48 24" fill="none" class="text-accent-purple/50">
            <path d="M0 12 L40 12 M34 6 L42 12 L34 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      </div>

      <!-- Output Box -->
      <div class="bg-surface border border-border-subtle rounded-xl p-6 w-full md:w-auto md:min-w-[200px] text-center">
        <h3 class="text-sm font-semibold text-text-primary/60 uppercase tracking-wider mb-3">Output</h3>
        <div class="flex flex-col gap-2">
          <code class="text-text-code font-mono text-sm bg-accent-purple/5 rounded-md px-3 py-1.5 inline-block">newState</code>
          <code class="text-text-code font-mono text-sm bg-accent-purple/5 rounded-md px-3 py-1.5 inline-block">VimAction[]</code>
        </div>
      </div>
    </div>

    <!-- VimAction types -->
    <div class="mb-16">
      <p class="text-sm text-text-primary/40 text-center mb-4 font-mono">VimAction types</p>
      <div class="flex flex-wrap justify-center gap-2">
        {
          vimActions.map((action) => (
            <span class="bg-surface border border-border-subtle rounded-full px-3 py-1 text-xs font-mono text-text-code">
              {action}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Key Selling Points -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
      {
        sellingPoints.map((point) => (
          <div class="flex items-start gap-3 p-4">
            <svg class="w-5 h-5 text-accent-purple shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">{point.title}</h4>
              <p class="text-sm text-text-primary/50">{point.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .process-box {
    box-shadow: 0 0 30px rgba(168, 130, 255, 0.08), 0 0 60px rgba(168, 130, 255, 0.04);
  }
</style>
