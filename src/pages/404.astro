---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Page Not Found | vimee" description="The page you're looking for doesn't exist.">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <img
        src="https://assets.vimee.dev/brandresource/vimee.svg"
        alt="vimee ghost mascot"
        class="w-24 h-24 mx-auto mb-8 ghost-404"
      />
      <h1 class="text-6xl md:text-8xl font-bold mb-4 tracking-tight" style="font-family: 'Jersey 15', sans-serif;">
        404
      </h1>
      <p class="text-lg text-text-primary/60 mb-2">
        This page doesn't exist.
      </p>
      <p class="text-sm text-text-primary/40 font-mono mb-10">
        :q! to go home
      </p>
      <a
        href="/"
        class="inline-flex items-center bg-accent-purple hover:brightness-110 hover:scale-105 transition-all duration-200 text-white font-semibold rounded-lg px-8 py-3"
      >
        Back to Home
      </a>
    </div>
  </main>
</Layout>

<style>
  .ghost-404 {
    animation: ghost-bob 3s ease-in-out infinite;
  }
</style>
