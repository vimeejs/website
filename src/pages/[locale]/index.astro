---
export function getStaticPaths() {
  return [{ params: { locale: "en" } }, { params: { locale: "ja" } }];
}

const { locale } = Astro.params;
const isJa = locale === "ja";

const t = {
  title: isJa ? "Web のためのヘッドレス Vim エンジン" : "Headless Vim Engine for the Web",
  sub: isJa
    ? "純粋関数。ゼロ依存。あらゆるフレームワーク。"
    : "Pure functions. Zero dependencies. Any framework.",
  getStarted: isJa ? "はじめる" : "Get Started",
  viewGithub: isJa ? "GitHub" : "GitHub",
  features: {
    pure: {
      title: isJa ? "純粋関数" : "Pure Functions",
      desc: isJa
        ? "すべての操作は純粋関数。状態を入力し、新しい状態を出力。副作用なし。"
        : "Every operation takes state in and returns new state out. No mutations, no surprises.",
    },
    zero: {
      title: isJa ? "ゼロ依存" : "Zero Dependencies",
      desc: isJa
        ? "コアエンジンに外部依存はなく、バンドルサイズを最小限に。"
        : "The core engine has no external dependencies. Keep your bundle lean.",
    },
    any: {
      title: isJa ? "あらゆるフレームワーク" : "Any Framework",
      desc: isJa
        ? "React、Vue、Svelte、バニラ JS。UI はあなたが構築し、vimee が Vim ロジックを担当。"
        : "React, Vue, Svelte, or vanilla JS. Bring your own UI, vimee handles the Vim.",
    },
    test: {
      title: isJa ? "テスタブル" : "Fully Testable",
      desc: isJa
        ? "純粋関数は簡単にテスト可能。@vimee/testkit でエルゴノミックなアサーション。"
        : "Pure functions are trivially testable. Use @vimee/testkit for ergonomic assertions.",
    },
  },
  liveDemo: isJa ? "ライブデモ" : "Live Demo",
  liveDemoSub: isJa ? "実際に Vim 操作を試してみてください" : "Try Vim operations right here",
  packages: isJa ? "パッケージ" : "Packages",
};

const packages = [
  { name: "@vimee/core", desc: isJa ? "Vim エンジン" : "Vim engine", href: `/${locale}/packages/core/` },
  { name: "@vimee/react", desc: isJa ? "React フック" : "React hooks", href: `/${locale}/packages/react/` },
  { name: "@vimee/shiki-editor", desc: isJa ? "Shiki エディター" : "Shiki editor", href: `/${locale}/packages/shiki-editor/` },
  { name: "@vimee/testkit", desc: isJa ? "テストユーティリティ" : "Test utilities", href: `/${locale}/packages/testkit/` },
  { name: "@vimee/plugin-monaco", desc: "Monaco", href: `/${locale}/packages/plugin-monaco/` },
  { name: "@vimee/plugin-codemirror", desc: "CodeMirror", href: `/${locale}/packages/plugin-codemirror/` },
];
import LiveDemo from "../../components/landing/LiveDemo";
---

<html lang={locale} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>vimee — {t.title}</title>
    <meta name="description" content={t.sub} />
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- ═══ HERO ═══ -->
    <section class="hero">
      <div id="shader-canvas" class="shader-bg"></div>
      <div class="hero-fade"></div>

      <nav class="hero-nav">
        <a href={`/${locale}/`} class="nav-logo">
          <img src="https://assets.vimee.dev/brandresource/vimee.svg" alt="" width="24" height="24" />
          <span>vimee</span>
        </a>
        <div class="nav-links">
          <a href={`/${locale}/getting-started/`}>Docs</a>
          <a href="https://github.com/vimeejs/vimee">GitHub</a>
          <a href={locale === "en" ? "/ja/" : "/en/"} class="nav-lang">
            {locale === "en" ? "日本語" : "English"}
          </a>
        </div>
      </nav>

      <div class="hero-content">
        <img
          src="https://assets.vimee.dev/brandresource/vimee.svg"
          alt="vimee ghost mascot"
          class="hero-mascot"
          width="80"
          height="80"
        />
        <h1 class="hero-title">vimee</h1>
        <p class="hero-tagline">{t.title}</p>
        <p class="hero-sub">{t.sub}</p>
        <div class="hero-cta">
          <a href={`/${locale}/getting-started/`} class="btn-primary">
            {t.getStarted}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://github.com/vimeejs/vimee" class="btn-ghost">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            {t.viewGithub}
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ FEATURES ═══ -->
    <section class="features">
      <div class="features-grid">
        <div class="feature-card" style="--delay: 0s">
          <div class="feature-icon">λ</div>
          <h3>{t.features.pure.title}</h3>
          <p>{t.features.pure.desc}</p>
        </div>
        <div class="feature-card" style="--delay: 0.1s">
          <div class="feature-icon">∅</div>
          <h3>{t.features.zero.title}</h3>
          <p>{t.features.zero.desc}</p>
        </div>
        <div class="feature-card" style="--delay: 0.2s">
          <div class="feature-icon">⟡</div>
          <h3>{t.features.any.title}</h3>
          <p>{t.features.any.desc}</p>
        </div>
        <div class="feature-card" style="--delay: 0.3s">
          <div class="feature-icon">✓</div>
          <h3>{t.features.test.title}</h3>
          <p>{t.features.test.desc}</p>
        </div>
      </div>
    </section>

    <!-- ═══ LIVE DEMO ═══ -->
    <section class="demo-section">
      <h2>{t.liveDemo}</h2>
      <p class="demo-sub">{t.liveDemoSub}</p>
      <div class="demo-container">
        <LiveDemo client:only="react" />
      </div>
    </section>

    <!-- ═══ PACKAGES ═══ -->
    <section class="packages">
      <h2>{t.packages}</h2>
      <div class="pkg-grid">
        {packages.map((pkg) => (
          <a href={pkg.href} class="pkg-card">
            <code>{pkg.name}</code>
            <span>{pkg.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="site-footer">
      <div class="footer-links">
        <a href={`/${locale}/getting-started/`}>Docs</a>
        <a href="https://github.com/vimeejs/vimee">GitHub</a>
        <a href="https://www.npmjs.com/package/@vimee/core">npm</a>
        <a href="https://playground.vimee.dev">Playground</a>
      </div>
      <p class="footer-copy">Built with pure functions</p>
    </footer>

    <!-- ═══ OGL SHADER ═══ -->
    <script>
      import { initPhantomShader } from "../../components/landing/PhantomShader";
      const container = document.getElementById("shader-canvas");
      if (container) {
        const cleanup = initPhantomShader(container);
        document.addEventListener("astro:before-swap", cleanup, { once: true });
      }
    </script>

    <!-- ═══ SCROLL REVEAL ═══ -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      document.querySelectorAll(".feature-card, .demo-container, .pkg-card").forEach((el) => {
        observer.observe(el);
      });
    </script>

    <style>
      @import url("https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600;700&display=swap");

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #050508;
        --surface: #0c0c14;
        --border: rgba(255,255,255,0.06);
        --text: #e8e6f0;
        --text-dim: rgba(232,230,240,0.45);
        --accent: hsl(280, 82%, 63%);
        --accent-glow: hsla(280, 82%, 63%, 0.15);
        --mono: "Geist Mono", "JetBrains Mono", monospace;
        --sans: "Inter", system-ui, sans-serif;
      }

      html { background: var(--bg); }
      body {
        font-family: var(--sans);
        color: var(--text);
        line-height: 1.6;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }

      /* ══ HERO ══ */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .shader-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
      }

      .hero-fade {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40%;
        background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
        z-index: 1;
      }

      .hero-nav {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 2rem;
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--mono);
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.95rem;
        color: var(--text-dim);
      }
      .nav-links a:hover { color: var(--text); }
      .nav-lang {
        padding: 0.25rem 0.6rem;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.8rem;
      }

      .hero-content {
        position: relative;
        z-index: 10;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 0 2rem 6rem;
      }

      .hero-mascot {
        width: 80px;
        height: 80px;
        margin-bottom: 1.5rem;
        filter: drop-shadow(0 0 20px hsla(280, 82%, 63%, 0.2));
      }

      .hero-title {
        font-family: var(--mono);
        font-size: clamp(3.5rem, 10vw, 7rem);
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.75rem;
        background: linear-gradient(135deg, var(--text) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-tagline {
        font-family: var(--mono);
        font-size: clamp(1.1rem, 2.5vw, 1.5rem);
        color: var(--text-dim);
        letter-spacing: -0.01em;
        margin-bottom: 0.5rem;
      }

      .hero-sub {
        font-size: 1rem;
        color: var(--text-dim);
        opacity: 0.6;
        margin-bottom: 2.5rem;
      }

      .hero-cta {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.6rem;
        background: var(--accent);
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        border-radius: 8px;
        transition: all 0.2s;
      }
      .btn-primary:hover {
        filter: brightness(1.15);
        transform: translateY(-1px);
        box-shadow: 0 4px 24px var(--accent-glow);
      }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.7rem 1.4rem;
        border: 1px solid var(--border);
        color: var(--text-dim);
        font-weight: 500;
        font-size: 1rem;
        border-radius: 8px;
        transition: all 0.2s;
      }
      .btn-ghost:hover {
        border-color: rgba(255,255,255,0.15);
        color: var(--text);
        background: rgba(255,255,255,0.03);
      }

      /* ══ FEATURES ══ */
      .features {
        padding: 5rem 2rem;
        max-width: 960px;
        margin: 0 auto;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
      }

      @media (max-width: 640px) {
        .features-grid { grid-template-columns: 1fr; }
      }

      .feature-card {
        background: var(--surface);
        padding: 2rem;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.5s ease, transform 0.5s ease;
        transition-delay: var(--delay, 0s);
      }
      .feature-card.revealed {
        opacity: 1;
        transform: translateY(0);
      }
      .feature-card:hover {
        background: rgba(255,255,255,0.02);
      }

      .feature-icon {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
        color: var(--accent);
        font-family: var(--mono);
      }

      .feature-card h3 {
        font-family: var(--mono);
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
      }

      .feature-card p {
        font-size: 0.95rem;
        color: var(--text-dim);
        line-height: 1.5;
      }

      /* ══ LIVE DEMO ══ */
      .demo-section {
        padding: 5rem 2rem;
        max-width: 780px;
        margin: 0 auto;
      }

      .demo-section h2 {
        font-family: var(--mono);
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        text-align: center;
        letter-spacing: -0.02em;
      }

      .demo-sub {
        text-align: center;
        color: var(--text-dim);
        font-size: 1rem;
        margin-bottom: 2rem;
      }

      .demo-container {
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.6s ease, transform 0.6s ease;
        /* Reset styles that leak into shiki-editor */
        line-height: normal;
        font-size: initial;
      }
      .demo-container * {
        box-sizing: content-box;
        margin: revert;
        padding: revert;
      }
      .demo-container.revealed {
        opacity: 1;
        transform: translateY(0);
      }

      /* ══ PACKAGES ══ */
      .packages {
        padding: 3rem 2rem 5rem;
        max-width: 680px;
        margin: 0 auto;
      }

      .packages h2 {
        font-family: var(--mono);
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        text-align: center;
        letter-spacing: -0.02em;
      }

      .pkg-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.5rem;
      }

      .pkg-card {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        transition: all 0.2s;
        opacity: 0;
        transform: translateY(12px);
      }
      .pkg-card.revealed {
        opacity: 1;
        transform: translateY(0);
      }
      .pkg-card:hover {
        border-color: var(--accent);
        background: var(--accent-glow);
      }
      .pkg-card code {
        font-family: var(--mono);
        font-size: 0.95rem;
        color: var(--accent);
      }
      .pkg-card span {
        font-size: 0.85rem;
        color: var(--text-dim);
      }

      /* ══ FOOTER ══ */
      .site-footer {
        text-align: center;
        padding: 3rem 2rem;
        border-top: 1px solid var(--border);
      }

      .footer-links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
      }
      .footer-links a {
        font-size: 0.9rem;
        color: var(--text-dim);
        transition: color 0.2s;
      }
      .footer-links a:hover { color: var(--text); }

      .footer-copy {
        font-size: 0.7rem;
        color: var(--text-dim);
        opacity: 0.4;
        font-family: var(--mono);
      }
    </style>
  </body>
</html>
